# ============================================================
# SISTEMA CAJADO — Variáveis de Ambiente (Railway)
# ============================================================
# Cole essas variáveis no painel do Railway:
# Projeto → Serviço → Variables
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ── App ──────────────────────────────────────────────────────
# Railway injeta PORT automaticamente — não altere
NEXT_PUBLIC_APP_NAME=Sistema Cajado
# Preencha com a URL gerada pelo Railway após o deploy:
NEXT_PUBLIC_APP_URL=https://cajado-sistema.up.railway.app

# ── Inbox / Bot (backend Railway) ────────────────────────────
NEXT_PUBLIC_INBOX_API_URL=https://cajado-inbox-backend.up.railway.app

# ── IA (OpenRouter) ──────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-sua_chave_aqui

# ── JWT (mesmo valor usado no inbox-backend) ─────────────────
JWT_SECRET=cajado-secret-2025
